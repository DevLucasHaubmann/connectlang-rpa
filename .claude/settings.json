{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/session-start.ps1",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Registering session in Obsidian..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/track-activity.ps1",
            "shell": "powershell",
            "timeout": 15,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/session-end.ps1",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Closing session log in Obsidian..."
          }
        ]
      }
    ]
  }
}